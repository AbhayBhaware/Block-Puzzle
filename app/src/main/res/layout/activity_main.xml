<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/game_background_gradient">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:layout_marginTop="24dp"
        android:gravity="center_vertical">

        <androidx.cardview.widget.CardView
            android:id="@+id/highScoreTextCard"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <TextView
                android:id="@+id/highScoreText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                app:drawableStartCompat="@drawable/baseline_military_tech_24"
                android:drawablePadding="8dp"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:layout_gravity="center"
                android:gravity="center"/>
        </androidx.cardview.widget.CardView>

        <View
            android:layout_width="12dp"
            android:layout_height="0dp"/>

        <androidx.cardview.widget.CardView
            android:id="@+id/cointextCard"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <TextView
                android:id="@+id/coinText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                app:drawableStartCompat="@drawable/coinlogoo"
                android:drawablePadding="8dp"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:layout_gravity="center"
                android:gravity="center"/>
        </androidx.cardview.widget.CardView>

        <View
            android:layout_width="12dp"
            android:layout_height="0dp"/>

        <androidx.cardview.widget.CardView
            android:id="@+id/menuButton"
            android:layout_width="50dp"
            android:layout_height="48dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/card_bg"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/menubtn"
                android:layout_gravity="center"
                app:tint="@color/white"
                android:contentDescription="Menu" />
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <com.abhay.blockblastify.StrokeTextView
        android:id="@+id/scoreText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SCORE 0"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="@color/accent_neon"
        android:fontFamily="sans-serif-black"
        android:background="@drawable/score_bg"
        android:layout_below="@id/topBar"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="16dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:letterSpacing="0.05"
        android:elevation="8dp"/>

    <com.abhay.blockblastify.GameView
        android:id="@+id/gameView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/scoreText"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"/>

    <!-- Dim Background Overlay -->
    <View
        android:id="@+id/dimBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#AA000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"
        android:elevation="50dp"/>

</RelativeLayout>
